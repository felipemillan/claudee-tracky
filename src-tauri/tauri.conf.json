{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claudee Tracky",
  "version": "0.1.0",
  "identifier": "com.claudee.tracky",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Claudee Tracky Dashboard",
        "width": 850,
        "height": 600,
        "resizable": true,
        "visible": false
      },
      {
        "label": "popup",
        "title": "Claudee Tracky Popup",
        "width": 320,
        "height": 330,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
